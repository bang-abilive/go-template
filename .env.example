APP_NAME=go-template
APP_ENV=development
APP_VERSION=0.0.1

SERVER_HOST=localhost
SERVER_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=go-template
DB_SCHEMA=public
DB_SSL_MODE=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_MAX_IDLE_CONNS=5
# DB_MAX_LIFETIME_CONNS=1h
DB_MAX_CONN_IDLE_TIME=10m
DB_MAX_CONN_LIFETIME=1h

GOOSE_DRIVER=postgres
GOOSE_DBSTRING="postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=${DB_SSL_MODE}&search_path=${DB_SCHEMA}"
GOOSE_MIGRATION_DIR=./migrations